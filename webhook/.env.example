# Configuración general
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Seguridad y CORS
# En desarrollo se permite "*". En producción, listar los orígenes permitidos separados por comas.
# Ejemplo: ALLOWED_ORIGINS=https://mi-frontend.com,https://app.mi-frontend.com
ALLOWED_ORIGINS=*

# Limitación de peticiones (Rate Limit)
# Número máximo de peticiones permitidas por segundo por dirección IP
RATE_LIMIT_PER_SECOND=35

# Configuración del Webhook de WhatsApp
# Token secreto de verificación configurado en el panel de desarrolladores de Meta (Requerido)
WHATSAPP_VERIFY_TOKEN=

# Clave secreta de la aplicación de Meta (App Secret) para validar firmas X-Hub-Signature-256 (Opcional en dev, Requerido en prod)
META_APP_SECRET=


# Base de Datos (opciones: sqlite | postgresql)
DATABASE_TYPE=sqlite
SQLITE_DB_PATH=./whatsapp_events.db

# Credenciales requeridas únicamente si DATABASE_TYPE=postgresql
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=


