# =========================================================================
# CONFIGURACIÓN GLOBAL DE ORQUESTACIÓN (docker-compose)
# =========================================================================
# Este archivo sirve para poblar las variables del archivo docker-compose.yml
# en la raíz del proyecto para pruebas locales con docker-compose.
# En Coolify (producción), estas variables se configuran en la UI del servicio.

# -------------------------------------------------------------------------
# Variables del Microservicio Webhook (FastAPI)
# -------------------------------------------------------------------------
# Orígenes CORS permitidos (Separados por comas. No usar "*" en producción)
ALLOWED_ORIGINS=*

# Máximo número de peticiones por segundo permitidas por IP
RATE_LIMIT_PER_SECOND=35

# Token de verificación para Meta (Handshake GET)
WHATSAPP_VERIFY_TOKEN=mi_token_de_verificacion_secreto_123

# Secreto de la App en Meta para validar firmas HMAC-SHA256 (Opcional en dev)
META_APP_SECRET=

# -------------------------------------------------------------------------
# Variables del Microservicio API (Central / Base de Datos)
# -------------------------------------------------------------------------
# Tipo de Base de Datos (sqlite | postgresql)
DATABASE_TYPE=sqlite
SQLITE_DB_PATH=./whatsapp_events.db

# Configuración de PostgreSQL (Requerido solo si DATABASE_TYPE=postgresql)
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

